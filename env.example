# ── NexusBot Node.js Server — Environment Variables ──────────────────────────
# Copy this file to .env and fill in your values.

# Supabase — get both from: https://supabase.com/dashboard/project/<id>/settings/api
SUPABASE_URL=https://bwywahzxddooktvajhfb.supabase.co
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY_HERE   # secret — never commit

# Server
PORT=3001
FRONTEND_URL=http://localhost:5173    # Vite dev server origin (for CORS)
API_BASE_URL=http://127.0.0.1:3001    # Base URL this server runs at — used in bot config files

# Stripe
# Use sk_test/whsec test values for sandbox. To go live, replace only env values.
STRIPE_SECRET_KEY=sk_test_your_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here
STRIPE_CURRENCY=usd
ALLOW_ADMIN_SUBSCRIPTION_GRANTS=false

# Python bot
# Absolute path to the Python interpreter inside the trading bot's venv
PYTHON_EXE=C:\Users\123\Desktop\AITradingBot\venv\Scripts\python.exe
# Absolute path to run_bot_managed.py
BOT_SCRIPT=C:\Users\123\Desktop\AITradingBot\scripts\run_bot_managed.py
# Directory where per-bot JSON config files are written before spawning
BOT_CONFIG_DIR=C:\Users\123\Desktop\AITradingBot\bot_configs
# Directory where Python bot stdout/stderr files are written for debugging startup errors
BOT_STDIO_LOG_DIR=C:\Users\123\Desktop\AITradingBot\bot_configs\process_logs

# Limit Python ML/math library threads. Required on shared hosts/cPanel.
OPENBLAS_NUM_THREADS=1
OMP_NUM_THREADS=1
MKL_NUM_THREADS=1
NUMEXPR_NUM_THREADS=1
VECLIB_MAXIMUM_THREADS=1
